# Where the deployed site reaches the Nukipa public API. Required.
# Copy the value from BRIEF.preload.md's "Gateway URL" line — it's
# already correct for the environment that generated this site (prod
# or staging). Don't guess; the wrong environment silently serves the
# wrong tenant data.
NUKIPA_GATEWAY_URL=

# Optional: pin the SDK to a specific tenant host instead of resolving
# from the request Host header. Only set when the site is reached
# through a CDN that rewrites Host, or for local dev against a
# specific tenant. Use the tenant's host (see BRIEF.preload.md).
# NUKIPA_TENANT_HOST=

# Floating in-page feedback widget (see src/components/NukipaFeedback.tsx).
# Defaults: shown only in production builds (the deployed preview the
# tenant reviews), hidden during `npm run dev`. The widget stores items
# in localStorage on the tenant's machine and offers "Copy all" - no
# backend round-trip needed.
# NUKIPA_FEEDBACK_DISABLED=1   # force-hide in production (post go-live)
# NUKIPA_FEEDBACK_ENABLED=1    # force-show in dev (when testing the widget)
